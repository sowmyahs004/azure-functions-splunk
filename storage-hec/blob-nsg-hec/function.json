{
  "bindings": [
    {
      "type": "blobTrigger",
      "name": "nsgBlobTrigger",
      "direction": "in",
      "connection": "BLOB_CONNECTION_STRING",
      "dataType": "string",
      "path": "%BLOB_PATH%/{blobName}"
    },
    {
      "name": "outputBlob",
      "type": "blob",
      "path": "undeliverable-nsg-events/{rand-guid}-{blobName}",
      "connection": "BLOB_CONNECTION_STRING",
      "direction": "out"
    }
  ]
}
